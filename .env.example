# ScrapeForge environment template. Copy to .env and fill in. NEVER commit the real .env.
# Generate a Fernet key:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Secrets (required) ---
STATE_STORE_KEY=                       # 32+ char base64 Fernet key (encrypts session state)
POSTGRES_PASSWORD=                     # Postgres password
API_KEYS=                             # comma-separated keys clients send as X-API-Key
API_DOMAIN=                           # public hostname for TLS (e.g. api.example.com)

# --- Datastore / queue (defaults match docker-compose service names) ---
DATABASE_URL=postgresql+asyncpg://scrapeforge:CHANGE_ME@postgres:5432/scrapeforge
REDIS_URL=redis://redis:6379/0

# --- Paths (inside the worker container; mounted from the state-data volume) ---
STATE_STORE_PATH=/data/states
PROXY_LIST_PATH=/data/proxies.txt
SESSION_TTL_DAYS=7

# --- Drivers ---
PATCHRIGHT_CHANNEL=chrome              # MUST be 'chrome', never 'chromium'
CURL_CFFI_IMPERSONATE=chrome
NODRIVER_SERVICE_URL=http://nodriver:8081

# --- Rate limiting / politeness ---
DEFAULT_RATE_INTERVAL_SECONDS=1.0
PREMIUM_MIN_INTERVAL_SECONDS=60.0

# --- Output / parsing ---
HTML_PARSER=selectolax
MIN_CONTENT_LENGTH=500

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Hezzian email digest (SMTP) ---
# Required to actually SEND (preview mode needs none of these):
DIGEST_SMTP_USER=your-sender@gmail.com      # the Gmail you send FROM (the SMTP login)
DIGEST_SMTP_PASSWORD=your-16-char-app-pass  # Gmail APP PASSWORD (enable 2FA, then generate one;
                                            # your normal password will NOT work)
DIGEST_TO=nayrbnat@gmail.com                # recipient for the prototype (overrides subscriber email)
# Optional (these defaults work for Gmail):
DIGEST_FROM=your-sender@gmail.com           # "From:" header; defaults to DIGEST_SMTP_USER
DIGEST_SMTP_HOST=smtp.gmail.com
DIGEST_SMTP_PORT=587

# --- Phase 2: LLM summarizer (z.ai / Zhipu GLM-4.5-Flash; free, OpenAI-compatible) ---
# Get a key at https://z.ai. Swap provider (DeepSeek/Qwen) by editing the API_*/MODEL lines.
# SUMMARY_PORTFOLIO / SUMMARY_INTERESTS personalize the 1-10 relevance score (comma-separated);
# fill them in your own .env, e.g. SUMMARY_PORTFOLIO=CompanyA,CompanyB
SUMMARY_API_KEY=
SUMMARY_MODEL=glm-4.5-flash
SUMMARY_API_BASE_URL=https://api.z.ai/api/paas/v4
SUMMARY_PORTFOLIO=
SUMMARY_INTERESTS=
